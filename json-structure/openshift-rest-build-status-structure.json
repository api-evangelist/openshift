{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "BuildStatus",
  "type": "object",
  "properties": {
    "phase": {
      "type": "string"
    },
    "cancelled": {
      "type": "boolean"
    },
    "message": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "startTimestamp": {
      "type": "string"
    },
    "completionTimestamp": {
      "type": "string"
    },
    "duration": {
      "type": "integer"
    },
    "outputDockerImageReference": {
      "type": "string"
    },
    "output": {
      "type": "object"
    },
    "logSnippet": {
      "type": "string"
    }
  }
}