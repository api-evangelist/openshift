{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Status",
  "type": "object",
  "description": "Status is a return value for calls that do not return other objects.",
  "properties": {
    "apiVersion": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "code": {
      "type": "integer"
    }
  }
}